            "post": {
                "summary": "Search Log Secure",
                "operationId": "search_log_secure_api_v1_search_secure__page___limit__post",
                "parameters": [
                    {
                        "name": "page",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "minimum": 1,
                            "title": "Page"
                        }
                    },
                    {
                        "name": "limit",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "maximum": 100,
                            "minimum": 1,
                            "title": "Limit"
                        }
                    },
                    {
                        "name": "authorization",
                        "in": "header",
                        "required": true,
                        "schema": {
                            "type": "string",
                            "description": "Format: Bearer <token>",
                            "title": "Authorization"
                        },
                        "description": "Format: Bearer <token>"
