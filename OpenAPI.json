        "/api/v1/search-post/{page}/{limit}": {
            "post": {
                "summary": "Search Log Post",
                "operationId": "search_log_post_api_v1_search_post__page___limit__post",
                "parameters": [
                    {
                        "name": "page",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "minimum": 1,
                            "title": "Page"
                        }
                    },
                    {
                        "name": "limit",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "integer",
                            "maximum": 100,
                            "minimum": 1,
                            "title": "Limit"
                        }
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "anyOf": [
                                    {
                                        "$ref": "#/components/schemas/SearchBody"
                                    },
                                    {
                                        "type": "null"
                                    }
                                ],
                                "title": "Payload"
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "Successful Response",
