    "components": {
        "schemas": {
            "DBCheckPayload": {
                "properties": {
                    "triggered_by": {
                        "type": "string",
                        "title": "Triggered By",
                        "default": "jenkins-pipeline"
                    },
                    "message": {
                        "type": "string",
                        "title": "Message",
                        "default": "Testing Write/Read capability"
                    }
                },
                "type": "object",
                "title": "DBCheckPayload"
            },
            "HTTPValidationError": {
                "properties": {
                    "detail": {
                        "items": {
                            "$ref": "#/components/schemas/ValidationError"
                        },
                        "type": "array",
                        "title": "Detail"
                    }
                },
                "type": "object",
                "title": "HTTPValidationError"
            },
            "SearchBody": {
                "properties": {
                    "keyword": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Keyword"
                    },
                    "status": {
                        "anyOf": [
                            {
                                "type": "string"
                            },
                            {
                                "type": "null"
                            }
                        ],
                        "title": "Status",
                        "default": "success"
                    },
                    "days_back": {
                        "type": "integer",
                        "title": "Days Back",
                        "default": 7
                    }
                },
                "type": "object",
                "title": "SearchBody"
            },
            "ValidationError": {
                "properties": {
                    "loc": {
                        "items": {
                            "anyOf": [
                                {
                                    "type": "string"
                                },
                                {
                                    "type": "integer"
                                }
                            ]
                        },
                        "type": "array",
                        "title": "Location"
                    },
                    "msg": {
                        "type": "string",
                        "title": "Message"
                    },
                    "type": {
                        "type": "string",
                        "title": "Error Type"
                    }
                },
                "type": "object",
                "required": [
                    "loc",
                    "msg",
                    "type"
                ],
                "title": "ValidationError"
            }
        }
    }
}